# ==================== 后端函数：APT ====================
run_apt() {
    case "$1" in
        install)
            shift; local resolved_pkgs=()
            mapfile -t resolved_pkgs < <(resolve_cross_distro_pkgs "$@")
            [[ ${#resolved_pkgs[@]} -eq 0 ]] && { info "$(_ no_pkgs)"; return 0; }
            info "$(_ installing "${resolved_pkgs[*]}")"
            sudo apt install -y "${resolved_pkgs[@]}"
            ;;
        remove)  shift; info "$(_ removing "$*")"; sudo apt remove -y "$@" ;;
        update)  info "$(_ upgrading)"; sudo apt update && sudo apt upgrade -y ;;
        upgrade)
            shift
            if [[ "$1" == "--refresh" ]]; then shift; info "$(_ upgrade_refresh)"; sudo apt update && sudo apt upgrade -y "$@"
            else info "$(_ upgrading)"; sudo apt upgrade -y "$@"; fi
            ;;
        search)  shift; info "$(_ searching "$*")"; apt search "$@" ;;
        pkginfo) shift; [[ $# -eq 0 ]] && error "$(_ err_pkg_info_need_name)"; apt show "$@" ;;
        clean)   info "$(_ clean_cache)"; sudo apt autoremove -y; sudo apt autoclean ;;
        *) error "$(_ err_unknown_action "$1")" ;;
    esac
}

