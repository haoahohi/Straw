# ==================== 发行版检测 ====================
detect_distro() {
    if [[ -f /etc/os-release ]]; then
        source /etc/os-release
        DISTRO="$ID"
        SYS_VERSION_ID="$VERSION_ID"
        VARIANT_ID="${VARIANT_ID:-}"

        IS_ATOMIC=false
        IS_UNIVERSAL_BLUE=false

        case "$ID" in
            fedora|centos|rhel|rocky|almalinux)
                if command -v rpm-ostree &>/dev/null && \
                   ([[ "$VARIANT_ID" =~ (atomic|silverblue|kinoite|bazzite|bluefin|aurora) ]] || \
                    [[ "$ID_LIKE" =~ "fedora" ]] && [[ -f /run/ostree-booted ]] || \
                    [[ -f /etc/ostree/remotes.d/fedora.conf ]]); then
                    IS_ATOMIC=true
                    PKG_BACKEND="ostree"
                    info "$(_ atomic_detected "$PRETTY_NAME")"

                    # 检测是否为 Universal Blue 变种
                    if [[ "$VARIANT_ID" =~ (bazzite|bluefin|aurora) ]] || \
                       [[ -d /usr/share/ublue-os ]]; then
                        IS_UNIVERSAL_BLUE=true
                        DISTRO="ub-${ID}"
                    fi
                else
                    PKG_BACKEND="dnf"
                fi
                ;;
            *)
                PKG_BACKEND="default"
                ;;
        esac
    elif [[ -f /etc/arch-release ]]; then
        DISTRO="arch"; PKG_BACKEND="pacman"
    elif [[ -f /etc/debian_version ]]; then
        DISTRO="debian"; PKG_BACKEND="apt"
    elif [[ -f /etc/void-release ]]; then
        DISTRO="void"; PKG_BACKEND="xbps"
    elif [[ -f /etc/alpine-release ]]; then
        DISTRO="alpine"; PKG_BACKEND="apk"
    else
        error "$(_ err_unknown_distro)"
    fi
}

# ==================== 包名解析 ====================
resolve_cross_distro_pkgs() {
    local -a input_pkgs=("$@") resolved_pkgs=()
    local -A seen_pkgs=()

    for pkg in "${input_pkgs[@]}"; do
        [[ -n "${seen_pkgs[$pkg]}" ]] && continue

        local mapped_pkg=""
        local found_mapping=false

        for key in "${!CROSS_DISTRO_PKG_MAP[@]}"; do
            if [[ "$key" == "$pkg" ]]; then
                IFS=' ' read -ra mappings <<< "${CROSS_DISTRO_PKG_MAP[$key]}"
                for mapping in "${mappings[@]}"; do
                    local prefix="${mapping%%:*}" value="${mapping#*:}"
                    if [[ "$DISTRO" == "$prefix" || "$DISTRO" =~ ^"$prefix" ]]; then
                        mapped_pkg="$value"
                        found_mapping=true
                        break 2
                    fi
                done
            fi
        done

        if [[ "$found_mapping" == true ]]; then
            if [[ "$mapped_pkg" == "__SKIP__" ]]; then
                info "$(_ pkg_skip "$pkg")"
                seen_pkgs[$pkg]=1
                continue
            fi

            echo -e "${GREEN}[straw]${NC} $(_ pkg_map "$DISTRO" "$pkg" "$mapped_pkg")" >&2

            IFS=' ' read -ra multi_pkgs <<< "$mapped_pkg"
            for mp in "${multi_pkgs[@]}"; do
                if [[ -z "${seen_pkgs[$mp]}" ]]; then
                    resolved_pkgs+=("$mp")
                    seen_pkgs[$mp]=1
                fi
            done
        else
            if [[ -z "${seen_pkgs[$pkg]}" ]]; then
                resolved_pkgs+=("$pkg")
                seen_pkgs[$pkg]=1
            fi
        fi

        seen_pkgs[$pkg]=1
    done

    printf "%s\n" "${resolved_pkgs[@]}"
}

