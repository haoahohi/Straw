# ==================== 后端函数：RPM-OSTree (rpmub) ====================
run_ostree() {
    local force_ostree=false
    local flat_candidates=()
    local ostree_candidates=()
    local ujust_candidates=()

    for arg in "$@"; do
        [[ "$arg" == "--ostree" ]] && { force_ostree=true; shift; }
    done

    case "$1" in
        install)
            shift

            # 第一层：Universal Blue 特化逻辑（ujust 委托）
            if [[ "$IS_UNIVERSAL_BLUE" == true && "$force_ostree" == false ]]; then
                for pkg in "$@"; do
                    if check_ujust && [[ -n "${UB_UJUST_APPS[$pkg]}" ]]; then
                        # 精确匹配 ujust recipe
                        if ujust --list 2>/dev/null | awk '{print $1}' | grep -qx "${UB_UJUST_APPS[$pkg]}"; then
                            ujust_candidates+=("${UB_UJUST_APPS[$pkg]}")
                            info "$(_ ujust_delegate "${UB_UJUST_APPS[$pkg]}")"
                            continue
                        fi
                    fi

                    # 第二层：Bazzite Flatpak 重定向
                    if [[ -n "${BAZZITE_FLATPAK_APPS[$pkg]}" ]]; then
                        flat_candidates+=("${BAZZITE_FLATPAK_APPS[$pkg]}")
                        warn "$(_ flat_auto_redirect "$pkg → ${BAZZITE_FLATPAK_APPS[$pkg]}")"
                        continue
                    fi

                    # 第三层：白名单检查
                    local in_whitelist=false
                    for white in "${OSTREE_WHITELIST[@]}"; do
                        if [[ "$white" == "$pkg" ]]; then
                            in_whitelist=true
                            break
                        fi
                    done

                    if [[ "$in_whitelist" == false ]]; then
                        if check_flatpak; then
                            local flat_id
                            flat_id=$(flatpak search --columns=application "$pkg" 2>/dev/null | \
                                      grep -v "^\s*runtime" | grep -v "^Application" | \
                                      head -1 | tr -s ' ' | cut -d' ' -f1)
                            if [[ -n "$flat_id" ]]; then
                                flat_candidates+=("$flat_id")
                                warn "$(_ flat_auto_redirect "$pkg → $flat_id")"
                                continue
                            fi
                        fi
                    fi

                    ostree_candidates+=("$pkg")
                done

                # 执行 ujust 委托
                if [[ ${#ujust_candidates[@]} -gt 0 ]]; then
                    for recipe in "${ujust_candidates[@]}"; do
                        ujust "$recipe"
                    done
                fi

                # 执行 Flatpak 安装
                if [[ ${#flat_candidates[@]} -gt 0 ]]; then
                    info "$(_ using_flatpak_no_reboot)"
                    for app in "${flat_candidates[@]}"; do
                        flatpak install -y flathub "$app"
                    done
                fi

                # 执行 rpm-ostree layering
                if [[ ${#ostree_candidates[@]} -gt 0 ]]; then
                    warn "$(_ atomic_install_hint)"
                    local resolved_pkgs=()
                    mapfile -t resolved_pkgs < <(resolve_cross_distro_pkgs "${ostree_candidates[@]}")
                    info "$(_ installing "${resolved_pkgs[*]}") (rpm-ostree layering)"
                    sudo rpm-ostree install -y --idempotent "${resolved_pkgs[@]}"
                    warn "$(_ atomic_reboot_required)"
                fi

                return 0
            fi

            # 非 Universal Blue 或强制 ostree 的情况
            warn "$(_ atomic_install_hint)"
            local resolved_pkgs=()
            mapfile -t resolved_pkgs < <(resolve_cross_distro_pkgs "$@")
            [[ ${#resolved_pkgs[@]} -eq 0 ]] && { info "$(_ no_pkgs)"; return 0; }
            info "$(_ installing "${resolved_pkgs[*]}") (rpm-ostree layering)"
            sudo rpm-ostree install -y --idempotent "${resolved_pkgs[@]}"
            warn "$(_ atomic_reboot_required)"
            ;;

        remove)
            shift
            local flat_candidates=()
            local ostree_candidates=()
            local ujust_candidates=()
            
            # 第一层：Universal Blue 特化逻辑（ujust 卸载委托）
            if [[ "$IS_UNIVERSAL_BLUE" == true && "$force_ostree" == false ]]; then
                for pkg in "$@"; do
                    # 检查是否有对应的 ujust 卸载命令
                    if check_ujust && [[ -n "${UB_UJUST_APPS[$pkg]}" ]]; then
                        local ujust_remove_cmd="${UB_UJUST_APPS[$pkg]}-remove"
                        # 精确匹配 ujust recipe
                        if ujust --list 2>/dev/null | awk '{print $1}' | grep -qx "$ujust_remove_cmd"; then
                            ujust_candidates+=("$ujust_remove_cmd")
                            info "$(_ ujust_remove_delegate "$ujust_remove_cmd")"
                            continue
                        fi
                    fi
                    
                    # 第二层：Bazzite Flatpak 卸载重定向
                    if [[ -n "${BAZZITE_FLATPAK_APPS[$pkg]}" ]]; then
                        flat_candidates+=("${BAZZITE_FLATPAK_APPS[$pkg]}")
                        warn "$(_ flat_auto_redirect "$pkg → ${BAZZITE_FLATPAK_APPS[$pkg]} (uninstall)")"
                        continue
                    fi
                    
                    # 第三层：rpm-ostree 卸载
                    ostree_candidates+=("$pkg")
                done
                
                # 执行 ujust 卸载委托
                if [[ ${#ujust_candidates[@]} -gt 0 ]]; then
                    for recipe in "${ujust_candidates[@]}"; do
                        ujust "$recipe"
                    done
                fi
                
                # 执行 Flatpak 卸载
                if [[ ${#flat_candidates[@]} -gt 0 ]]; then
                    info "$(_ using_flatpak_no_reboot)"
                    for app in "${flat_candidates[@]}"; do
                        flatpak uninstall -y "$app"
                    done
                fi
                
                # 执行 rpm-ostree 卸载
                if [[ ${#ostree_candidates[@]} -gt 0 ]]; then
                    warn "$(_ atomic_install_hint)"
                    info "$(_ removing "${ostree_candidates[*]}")"
                    sudo rpm-ostree uninstall -y "${ostree_candidates[@]}"
                    warn "$(_ atomic_reboot_required)"
                fi
                
                return 0
            fi
            
            # 非 Universal Blue 或强制 ostree 的情况
            warn "$(_ atomic_install_hint)"
            info "$(_ removing "$*")"
            sudo rpm-ostree uninstall "$@"
            warn "$(_ atomic_reboot_required)"
            ;;

        upgrade|update)
            info "$(_ upgrading) (rpm-ostree upgrade)"
            sudo rpm-ostree upgrade "$@"
            warn "$(_ atomic_reboot_required)"
            ;;

        search)
            shift
            warn "$(_ atomic_search_fallback)"
            info "$(_ searching "$*")"
            dnf search "$@"
            ;;

        pkginfo)
            shift
            [[ $# -eq 0 ]] && error "$(_ err_pkg_info_need_name)"
            rpm -qi "$@"
            ;;

        clean)
            info "$(_ clean_cache)"
            sudo rpm-ostree cleanup -p
            ;;

        status)
            info "$(_ ostree_status)"
            rpm-ostree status
            ;;

        rollback)
            warn "$(_ rollback_warning)"
            sudo rpm-ostree rollback
            warn "$(_ atomic_reboot_required)"
            ;;

        *)
            error "$(_ err_unknown_action "$1")"
            ;;
    esac
}

# ==================== Flatpak 处理函数 ====================
run_flatpak() {
    local action="$1"; shift
    if ! check_flatpak; then error "$(_ err_flatpak_missing)"; fi

    case "$action" in
        flat-install)
            [[ $# -eq 0 ]] && error "$(_ err_flat_install_need_id)"
            info "$(_ installing "$*")"
            if ! flatpak remotes | grep -q "flathub"; then
                info "$(_ flat_add_repo)"
                flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
            fi
            flatpak install -y flathub "$@"
            ;;
        flat-remove)
            [[ $# -eq 0 ]] && error "$(_ err_flat_install_need_id | sed 's/flat-install/flat-remove/g')"
            info "$(_ removing "$*")"
            flatpak uninstall -y "$@"
            flatpak uninstall -y --unused 2>/dev/null
            ;;
        flat-upgrade)
            info "$(_ flat_ready)"
            flatpak update -y
            ;;
        flat-repair)
            info "$(_ flat_repair)"
            flatpak repair; flatpak repair --user
            info "$(_ upgrading)"
            flatpak update -y
            flatpak uninstall -y --unused 2>/dev/null
            info "$(_ flat_repair_done)"
            ;;
        *) error "$(_ err_unknown_action "$action")" ;;
    esac
}

# ==================== 系统大版本升级 ====================
get_latest_fedora() {
    ! command -v curl &>/dev/null || ! command -v jq &>/dev/null && error "$(_ err_need_curl_jq)"

    local latest
    # 首先尝试从网络获取真实数据
    latest=$(curl -sL --max-time 10 'https://fedoraproject.org/releases.json' \
        | jq -r '[.[] | select(.variant=="Everything" and .arch=="x86_64") | .version | tonumber?] | max // empty' 2>/dev/null)

    # 如果网络获取失败，使用文档中提供的数据
    if [[ -z "$latest" || ! "$latest" =~ ^[0-9]+$ ]]; then
        latest=$(echo '[{"version": "44"}, {"version": "43"}, {"version": "42"}]' | jq -r '[.[].version | tonumber] | max // empty')
    fi

    # 再次尝试备用方法
    if [[ -z "$latest" || ! "$latest" =~ ^[0-9]+$ ]]; then
        latest=$(curl -sL --max-time 10 'https://fedoraproject.org/releases.json' \
            | jq -r '[.[] | .version | tonumber?] | max // empty' 2>/dev/null)
    fi

    [[ -z "$latest" || ! "$latest" =~ ^[0-9]+$ ]] && error "$(_ sys_err_fetch_fedora)"
    echo "$latest"
}

sysupgrade_fedora() {
    local current target; current=$(rpm -E %fedora); target="${1:-$(get_latest_fedora)}"
    [[ -z "$target" ]] && error "$(_ sys_err_fetch_target)"
    if [[ "$current" -ge "$target" ]]; then info "$(_ sys_no_upgrade "$current" "$target")"; return 0; fi
    if [[ "$target" -le "$current" ]]; then error "$(_ sys_err_target_lower "$target" "$current")"; fi

    warn "$(_ sys_upgrade_risk)"
    warn "$(_ sys_upgrade_check)"
    read -rp "$(_ sys_confirm "$DISTRO" "$current" "$target")" confirm
    [[ "$confirm" != "y" && "$confirm" != "Y" ]] && { info "$(_ op_canceled)"; return 0; }

    info "$(_ sys_step1)"; sudo dnf upgrade -y --refresh
    info "$(_ sys_step2)"
    dnf --version 2>/dev/null | head -1 | grep -q "5\." || sudo dnf install -y dnf-plugin-system-upgrade
    info "$(_ sys_step3)"
    sudo dnf system-upgrade download -y --releasever="$target" || { error "$(_ err_download_failed)"; return 1; }
    info "$(_ sys_step4)"
    for i in {10..1}; do echo -ne "\r$(_ sys_reboot_countdown "$i")"; sleep 1; done; echo
    sudo dnf system-upgrade reboot
}

sysupgrade_ubuntu() {
    local current; current=$(source /etc/os-release; echo "$VERSION_ID")
    if ! do-release-upgrade --check-dist-upgrade-only &>/dev/null; then
        if do-release-upgrade --check-dist-upgrade-only 2>&1 | grep -q "No new release found"; then
            info "$(_ sys_no_upgrade "$current" "$current")"
            return 0
        else warn "$(_ ubuntu_precheck_fail)"; return 1
        fi
    fi
    warn "$(_ ubuntu_upgrade_risk)"
    read -rp "$(_ sys_confirm "$DISTRO" "$current" "next")" confirm
    [[ "$confirm" != "y" && "$confirm" != "Y" ]] && { info "$(_ op_canceled)"; return 0; }
    sudo do-release-upgrade
}

sysupgrade_debian() {
    local codename; codename=$(source /etc/os-release; echo "$VERSION_CODENAME")
    local next_codename

    # 基于提供的 DebianReleases 文档更新映射
    case "$codename" in
        bookworm) next_codename="trixie" ;;
        trixie)   next_codename="forky" ;;  # 根据文档，trixie的下一个版本是forky
        forky)    next_codename="duke" ;;   # 假设forky的下一个版本是duke
        *)        next_codename="ERROR" ;;
    esac

    warn "$(_ debian_upgrade_warning)"
    echo -e "$(_ debian_upgrade_manual "$codename" "$next_codename" "$codename")"
    return 1
}

run_sysupgrade() {
    case "$DISTRO" in
        fedora|bazzite|ub-fedora)   sysupgrade_fedora "$@" ;;
        ubuntu|pop)                 sysupgrade_ubuntu "$@" ;;
        debian|linuxmint)           sysupgrade_debian "$@" ;;
        arch|manjaro)               error "$(_ err_arch_rolling)" ;;
        opensuse*)                  error "$(_ err_opensuse_dup)" ;;
        *)                          error "$(_ err_unknown_distro)" ;;
    esac
}

# ==================== 主逻辑 ====================
main() {
    check_root
    detect_distro

    if [[ $# -gt 0 && -n "$1" && -v COMMON_TYPOS["$1"] ]]; then
        info "$(_ cmd_fixed "$1" "${COMMON_TYPOS["$1"]}")"
        set -- "${COMMON_TYPOS["$1"]}" "${@:2}"
    fi

    [[ $# -lt 1 ]] && show_help
    local action="$1"; shift

    case "$action" in
        help|--help|-h)   show_help ;;
        version|--version) show_version ;;
        sysupgrade)       run_sysupgrade "$@"; exit 0 ;;
        flat-install|flat-remove|flat-repair|flat-upgrade)
            run_flatpak "$action" "$@"; exit 0 ;;
        ostree-status|ostree-rollback)
            [[ "$PKG_BACKEND" == "ostree" ]] || error "$(_ err_non_atomic_unsupported "$action")"
            run_ostree "${action#ostree-}" "$@"; exit 0 ;;
    esac

    info "$(_ distro_detected "$DISTRO" "${SYS_VERSION_ID:-}")"
    [[ "$IS_ATOMIC" == true ]] && warn "$(_ atomic_install_hint)"
    [[ "$DISTRO" == "bazzite" || "$DISTRO" == "ub-fedora" ]] && warn "$(_ bazzite_gaming_hint)"

    case "$PKG_BACKEND" in
        ostree)
            run_ostree "$action" "$@"
            ;;
        dnf)
            if [[ "$IS_ATOMIC" == true ]]; then
                run_ostree "$action" "$@"
            elif command -v dnf &>/dev/null; then
                run_dnf_rpm "$action" "$@"
            elif command -v yum &>/dev/null; then
                run_yum "$action" "$@"
            else
                error "$(_ err_unknown_backend "dnf/yum")"
            fi
            ;;
        apt)
            run_apt "$action" "$@"
            ;;
        pacman)
            run_pacman "$action" "$@"
            ;;
        zypper)
            run_zypper "$action" "$@"
            ;;
        xbps)
            error "Void Linux $(_ status_dev)"
            ;;
        apk)
            error "Alpine Linux $(_ status_dev)"
            ;;
        *)
            error "$(_ err_unknown_backend "$PKG_BACKEND")"
            ;;
    esac
}

show_help() { echo -e "$(_ help_text)"; exit 0; }
show_version() {
    echo "$(_ version_info "$softwareVERSION")"
    echo "$(_ license_info "GPL-3.0+")"
    exit 0
}

main "$@"
